---
import Section from '@components/Section.astro';

interface Props {
  heading?: string;
  body?: string;
  videoUrl?: string;
  'data-sb-field-path'?: string;
}

const { heading, body, videoUrl = '', ...rest } = Astro.props;

// Soporta YouTube y Vimeo
function getEmbedUrl(url: string): string {
  if (!url) return '';
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}?autoplay=0&rel=0&modestbranding=1`;
  const vim = url.match(/vimeo\.com\/(\d+)/);
  if (vim) return `https://player.vimeo.com/video/${vim[1]}`;
  return url;
}

const embedUrl = getEmbedUrl(videoUrl);
---

<Section {...rest}>
  <div class="video-section-inner">
    {heading && (
      <h2 class="text-2xl font-black sm:text-4xl text-balance text-center mb-4">
        {heading}
      </h2>
    )}
    {body && (
      <p class="text-center max-w-2xl mx-auto mb-10 opacity-80">{body}</p>
    )}
    {embedUrl && (
      <div class="video-wrapper">
        <iframe
          src={embedUrl}
          title={heading ?? 'Video'}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        />
      </div>
    )}
  </div>
</Section>

<style>
  .video-section-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    border-radius: 1rem;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4);
  }
  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>